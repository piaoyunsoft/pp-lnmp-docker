# 默认: 仓库内全 LF (跨平台一致)
* text=auto eol=lf

# Bash 脚本必须 LF (Linux 才能执行)
scripts/lnmp        text eol=lf
scripts/cron-backup text eol=lf

# Shell / 配置
*.sh                text eol=lf
*.conf              text eol=lf
*.ini               text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
Dockerfile*         text eol=lf
.env*               text eol=lf

# Windows 专用保 CRLF
*.cmd               text eol=crlf
*.bat               text eol=crlf
*.ps1               text eol=crlf

# 二进制
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.gz   binary
*.zip  binary
*.tar  binary
*.cer  binary
*.key  binary
