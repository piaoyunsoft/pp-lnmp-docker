# ============================================================
# LNMP Docker - 全局配置 (复制为 .env)
#
# Author:  PiaoYun <piaoyunsoft@163.com>
# Website: https://www.chinapyg.com
# License: MIT
# ============================================================
COMPOSE_PROJECT_NAME=pp_lnmp
TZ=Asia/Shanghai

# ---------- 网络 ----------
LNMP_NETWORK=pp_lnmp_net
LNMP_SUBNET=172.28.0.0/16

# ---------- 端口绑定 (生产安全) ----------
# 开发(本机): 留空 = 0.0.0.0 (所有网卡可访问)
# 生产服务器: 设为 127.0.0.1 = 只本机访问, 业务通过 nginx 反代
#   MySQL/Redis/Adminer 都用 BIND_HOST_ADMIN, 强烈建议 127.0.0.1
BIND_HOST=
BIND_HOST_ADMIN=127.0.0.1

# ---------- MySQL 8.4 (主) ----------
# 只保留 root, 业务库/用户用 `lnmp db:create` 按需建, 凭据写入站点 sites/<域>/.env
MYSQL_VERSION=8.4
MYSQL_ROOT_PASSWORD=ChangeMe_Strong_Root_Pass!
MYSQL_PORT=3306
# 内存的 50%-70%; 8G 服务器给 4G, 16G 给 10G
MYSQL_INNODB_BUFFER_POOL_SIZE=512M
# buffer pool 切片; >= 1G 时设为 buffer_pool_size 的 GB 数
MYSQL_INNODB_BUFFER_POOL_INSTANCES=1
MYSQL_MAX_CONNECTIONS=500

# ---------- MySQL 5.7 (老站兼容, 按需启动: `lnmp up mysql57`) ----------
# 容器内主机名: mysql57 / mysql5
# 留空 MYSQL57_ROOT_PASSWORD 则复用 MYSQL_ROOT_PASSWORD
MYSQL57_VERSION=5.7
MYSQL57_ROOT_PASSWORD=
MYSQL57_PORT=3307
MYSQL57_INNODB_BUFFER_POOL_SIZE=256M
MYSQL57_MAX_CONNECTIONS=300

# ---------- Redis ----------
REDIS_VERSION=7.4-alpine
REDIS_PASSWORD=ChangeMe_Redis_Pass!
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# ---------- 管理面板端口 (默认绑 BIND_HOST_ADMIN, 强烈建议本机) ----------
ADMINER_PORT=8080

# ---------- acme.sh ----------
ACME_EMAIL=you@example.com
# DNS API 留空则用 webroot(http-01)。常用: dns_cf / dns_ali / dns_dp
ACME_DNS_API=
# Cloudflare:
CF_Token=
CF_Account_ID=
CF_Zone_ID=
# 阿里云:
Ali_Key=
Ali_Secret=

# ---------- Nginx Gateway ----------
NGINX_VERSION=1.30.1-alpine
HTTP_PORT=80
HTTPS_PORT=443

# ---------- PHP 默认版本 ----------
# 每站点可覆盖, 支持 5.6 / 7.0-7.4 / 8.0-8.4
PHP_DEFAULT_VERSION=8.3

# ---------- Docker 日志大小 (避免撑爆磁盘) ----------
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
